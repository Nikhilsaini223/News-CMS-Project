<script>

  // Get the users data from the server-side and pass it to the client-side
  const tableData = <%- JSON.stringify(users) %>

  // Initialize Tabulator table
  var table = new Tabulator("#usersTable", {
      data: tableData,
      layout: "fitColumns",
      pagination: true,
      paginationSize: 10,
      paginationSizeSelector: [5, 10, 25, 50, 100],
      columns: [
          { title: "Full Name", field: "fullName", headerFilter: "input" },
          { title: "User Name", field: "userName", headerFilter: "input" },
          { title: "Role", field: "role", headerFilter: "input" },
          {
              title: "Actions",
              formatter: function (cell, formatterParams, onRendered) {
                  return `
                      <a href="/admin/update-user/${cell.getData()._id}" class="btn btn-sm btn-success">Edit</a>
                      <button class="btn btn-sm btn-danger delete-user" onclick="deleteUser('${cell.getData()._id}')">Delete</button>
                  `;
              }
          }
      ]
  });

// Delete user function
async function deleteUser(id){
  try {
    if (confirm("Are you sure you want to delete this user?")) {
      const response = await fetch(`/admin/delete-user/${id}`, {
        method: 'delete'
      });
      if(response.ok){
        window.location.reload();
      }

      if(response.status == 400){
        const data = await response.json();
        alert(data.message);
      }
      
    }
  } catch (error) {
    console.log(error);
  }
}


</script>

