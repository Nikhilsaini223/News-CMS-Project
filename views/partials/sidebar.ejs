<div id="sidebar" class="col-lg-4 col-md-12">
  <div class="search-box-container">
      <h4>Search</h4>
      <form class="search-post" action="/search" method="GET">
          <div class="search-form-row">
              <input type="text" name="search" class="form-control" placeholder="Search stories">
              <button type="submit" class="btn" aria-label="Search">
                  <i class="fa fa-search"></i>
              </button>
          </div>
      </form>
  </div>

  <div class="recent-post-container">
      <h4>Recent Posts</h4>
      <% latestNews.forEach(function(latestNew){ %>
      <div class="recent-post">
          <a class="post-img" href="/single/<%= latestNew._id %>">
              <img src="/uploads/<%= latestNew.image %>" alt=""/>
          </a>
          <div class="post-content">
              <h5><a href="/single/<%= latestNew._id %>"><%= latestNew.title %></a></h5>
              <span>
                  <i class="fa fa-tags" aria-hidden="true"></i>
                  <% if (latestNew.category) { %>
                      <a href="/category/<%= latestNew.category.slug %>"><%= latestNew.category.name %></a>
                  <% } else { %>
                      <span>Uncategorized</span>
                  <% } %>
              </span>
              <span>
                  <i class="fa fa-calendar" aria-hidden="true"></i>
                  <%= new Date(latestNew.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }).replace(/\s/g, ', ') %>
              </span>
          </div>
      </div>
      <% }); %>
  </div>
</div>