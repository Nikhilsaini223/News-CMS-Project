<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>ADMIN Panel</title>
    <!-- Font Awesome Icon (CDN) -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Admin stylesheet -->
    <link rel="stylesheet" href="/css/admin.css" />

    <%- typeof tabulatorCSS == 'undefined' ? '' : tabulatorCSS %>

  </head>
  <body>
    <!-- HEADER -->
    <div id="header-admin">
      <div class="admin-header-row">
        <!-- LOGO -->
        <a href="/admin/dashboard"
          ><img class="logo" src="/images/news.jpeg" alt="Logo"
        /></a>
        <!-- /LOGO -->
        <!-- LOG-Out -->
        <a href="/admin/logout" class="admin-logout">
          <i class="fa fa-sign-out"></i> logout
        </a>
        <!-- /LOG-Out -->
      </div>
    </div>
    <!-- /HEADER -->

    <!-- Menu Bar -->
    <div id="admin-menubar">
      <ul class="admin-menu">
        <li><a href="/admin/dashboard">Home</a></li>
        <li><a href="/admin/article">Article</a></li>
   <% if(role === 'admin') { %>     
        <li><a href="/admin/category">Category</a></li>
        <li><a href="/admin/users">Users</a></li>   
     <% } %>   
        <li><a href="/admin/comments">Comments</a></li>
    <% if(role === 'admin') { %>     
        <li><a href="/admin/settings">Settings</a></li>
     <% } %>    
      </ul>
    </div>
    <!-- /Menu Bar -->

    <%- body %>

    <!-- Footer -->
    <div id="footer">
      <span>© Copyright 2026 News | Powered by Nikhil Saini</span>
    </div>
    <!-- /Footer -->
  </body>
</html>
