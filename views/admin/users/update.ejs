<link rel="stylesheet" href="/css/users.css" />
<div id="admin-content">
  <h1 class="admin-heading">Modify User Details</h1>

  <div class="form-card">
    <h5 class="form-card-header">Update User</h5>
    <div class="form-card-body">
      <!-- Form Start -->
      <form action="/admin/update-user/<%= user.id %>" method="POST" autocomplete="off">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="fullName" value="<%= user.fullName %>" placeholder="Full Name" required />
        </div>
        <div class="form-group">
          <label>User Name</label>
          <input type="text" name="userName" value="<%= user.userName %>" placeholder="Username" disabled />
        </div>
        <div class="form-group">
          <label>Password</label>
          <input
            type="password"
            name="password"
            placeholder="Password"
          />
        </div>
        <div class="form-group">
          <label>User Role</label>
          <select name="role">
            <option value="author" <%= user.role === 'author' ? 'selected' : '' %>>Author</option>
            <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Administrator</option>
          </select>
        </div>
        <input type="submit" name="save" value="Update" required />
      </form>
      <!-- Form End-->
    </div>
  </div>
</div>
